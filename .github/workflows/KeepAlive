name: Keep Alive

on:
  schedule:
    - cron: '0 12 1 * *'   # día 1 de cada mes a las 12:00 UTC
  workflow_dispatch:

jobs:
  keepalive:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: 📥 Descargar repositorio
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GH_TOKEN }}

      - name: 💓 Commit keep-alive
        run: |
          git config user.name "AlertasBot"
          git config user.email "bot@alertas.com"
          echo "$(date -u)" > keepalive.txt
          git add keepalive.txt
          git commit -m "💓 Keep alive $(date -u '+%Y-%m')"
          git push
